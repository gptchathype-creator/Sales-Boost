// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Core web identity. This is the future source of truth for auth/RBAC.
/// Existing Telegram-first flow can keep using `User` until the app layer is migrated.
model Account {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  displayName    String?
  status         String   @default("active") // "active" | "invited" | "disabled"
  emailVerifiedAt DateTime?
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  telegramUsers  User[]
  telegramLinks  TelegramLink[]
  telegramLinkCodes TelegramLinkCode[]
  memberships    AccountMembership[]
  managerProfiles ManagerProfile[]
  createdPermissionTemplates PermissionTemplate[] @relation("PermissionTemplateCreatedBy")
  permissionTemplateAssignments AccountPermissionTemplateAssignment[]

  @@map("accounts")
}

/// Organizational root: a holding/group of dealerships.
model Holding {
  id          String   @id @default(cuid())
  name        String
  code        String?  @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dealerships Dealership[]
  memberships AccountMembership[]

  @@map("holdings")
}

/// A single dealership belonging to a holding.
model Dealership {
  id          String   @id @default(cuid())
  holdingId   String?
  name        String
  code        String?  @unique
  city        String?
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  holding         Holding?            @relation(fields: [holdingId], references: [id], onDelete: SetNull)
  memberships     AccountMembership[]
  managerProfiles ManagerProfile[]

  @@index([holdingId])
  @@map("dealerships")
}

/// Business profile of a dealership employee/manager.
/// Optional links let us migrate gradually from the current Telegram `User` model.
model ManagerProfile {
  id              String   @id @default(cuid())
  dealershipId    String
  accountId       String?
  telegramUserId  Int?     @unique
  fullName        String
  email           String?
  phone           String?
  status          String   @default("active") // "active" | "inactive"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  dealership      Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  account         Account?   @relation(fields: [accountId], references: [id], onDelete: SetNull)
  telegramUser    User?      @relation("TelegramUserManagerProfile", fields: [telegramUserId], references: [id], onDelete: SetNull)

  @@index([dealershipId])
  @@index([accountId])
  @@map("manager_profiles")
}

/// Scope-aware role assignment. This is the RBAC layer:
/// - platform_superadmin => holdingId/dealershipId are null
/// - holding_admin       => holdingId is set
/// - dealership_admin    => dealershipId is set
/// - manager             => dealershipId is set
model AccountMembership {
  id           String   @id @default(cuid())
  accountId    String
  role         String   // "platform_superadmin" | "holding_admin" | "dealership_admin" | "manager"
  holdingId    String?
  dealershipId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account      Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  holding      Holding?   @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  dealership   Dealership? @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  @@index([accountId, role])
  @@index([holdingId, role])
  @@index([dealershipId, role])
  @@unique([accountId, role, holdingId, dealershipId])
  @@map("account_memberships")
}

model PermissionTemplate {
  id                String   @id @default(cuid())
  name              String
  description       String?
  permissionsJson   String   // JSON array of permission keys
  isSystem          Boolean  @default(false)
  createdByAccountId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  createdBy         Account? @relation("PermissionTemplateCreatedBy", fields: [createdByAccountId], references: [id], onDelete: SetNull)
  assignments       AccountPermissionTemplateAssignment[]

  @@unique([name])
  @@index([createdByAccountId])
  @@map("permission_templates")
}

model AccountPermissionTemplateAssignment {
  id          String   @id @default(cuid())
  accountId   String
  templateId  String
  createdAt   DateTime @default(now())

  account     Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  template    PermissionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([accountId, templateId])
  @@index([accountId])
  @@index([templateId])
  @@map("account_permission_template_assignments")
}

/// Explicit Telegram<->Account binding for a future account-first auth flow.
/// Kept separate from `User` so the current Telegram bot logic can keep running during migration.
model TelegramLink {
  id               String   @id @default(cuid())
  accountId        String
  telegramId       String   @unique
  telegramUsername String?
  linkedAt         DateTime @default(now())
  lastSeenAt       DateTime?

  account          Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("telegram_links")
}

/// One-time code to link a logged-in web account with Telegram via the bot.
model TelegramLinkCode {
  id          String   @id @default(cuid())
  accountId   String
  code        String   @unique
  purpose     String   @default("link_telegram")
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())

  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, purpose])
  @@index([expiresAt])
  @@map("telegram_link_codes")
}

model User {
  id              Int      @id @default(autoincrement())
  telegramId      String   @unique
  fullName        String
  role            String   @default("manager") // "manager" | "admin"
  preferencesJson String?  // { replyMode: "text"|"voice", ttsVoice: "male"|"female" }
  accountId       String?
  createdAt       DateTime @default(now())

  attempts         Attempt[]
  trainingSessions TrainingSession[]
  account          Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  managerProfile   ManagerProfile? @relation("TelegramUserManagerProfile")

  @@index([accountId])
  @@map("users")
}

model TrainingSession {
  id               Int       @id @default(autoincrement())
  userId           Int
  // "assigned" | "in_progress" | "completed" | "cancelled" | "failed"
  status           String
  // "normal" | "thorough" | "pressure"
  clientProfile    String    @default("normal")
  // JSON: extended dialog state (phase, topics, checklist, health, etc.)
  stateJson        String?
  createdAt        DateTime  @default(now())
  completedAt      DateTime?
  // Legacy assessment fields (kept for backward compatibility)
  assessmentScore  Float?    // 0-100
  assessmentJson   String?   // JSON: legacy training assessment
  // V2 evaluation fields
  failureReason    String?   // "poor_communication" | "ignored_questions" | "rude_language" | "repeated_low_effort" | "critical_evasion:topic"
  evaluationJson   String?   // Strict V2 JSON: { overall_score_0_100, dimension_scores, checklist, issues, recommendations }
  totalScore       Float?    // 0-100, deterministic score from evaluator

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages DialogMessage[]

  @@map("training_sessions")
}

model DialogMessage {
  id        Int      @id @default(autoincrement())
  sessionId Int
  role      String   // "client" | "manager"
  content   String
  source    String   @default("text") // "text" | "voice"
  voiceFileId      String?
  voiceDurationSec Int?
  qualitySignalJson String? // JSON: { very_short, nonsense, profanity, filler_count, anglicism_count }
  createdAt DateTime @default(now())

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("dialog_messages")
}

model Test {
  id                    Int       @id @default(autoincrement())
  title                 String
  isActive              Boolean   @default(true)
  useVirtualCustomer    Boolean   @default(false)
  virtualCustomerConfigJson String? // JSON: { car: {...}, dealership: "..." }
  createdAt             DateTime  @default(now())

  steps   TestStep[]
  attempts Attempt[]

  @@map("tests")
}

model TestStep {
  id               Int    @id @default(autoincrement())
  testId           Int
  order            Int
  customerMessage  String
  stepGoal         String
  scoringFocusJson String // JSON array of criteria codes

  test           Test            @relation(fields: [testId], references: [id], onDelete: Cascade)
  attemptAnswers AttemptAnswer[]

  @@unique([testId, order])
  @@map("test_steps")
}

model Attempt {
  id                     Int       @id @default(autoincrement())
  userId                 Int
  testId                 Int
  status                 String    // "in_progress" | "completed" | "cancelled"
  currentStep            Int       @default(1)
  startedAt              DateTime  @default(now())
  finishedAt             DateTime?
  lastStepSentAt         DateTime? // When last step was sent (for timeout tracking)
  totalScore             Float?
  level                  String?   // "Junior" | "Middle" | "Senior"
  strengthsJson          String?   // JSON array
  weaknessesJson         String?   // JSON array
  recommendationsJson    String?   // JSON array
  suspicionFlagsJson     String?   // JSON array
  evaluationError        String?
  evaluationResultJson   String?   // JSON: full evaluation result (for virtual customer step details)
  conversationHistoryJson String?  // JSON array of { role: "client"|"manager", text: string } (virtual customer)
  virtualCustomerStateJson String? // JSON: { stage, checklist, notes } (virtual customer)

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  test    Test           @relation(fields: [testId], references: [id])
  answers AttemptAnswer[]

  @@map("attempts")
}

model AttemptAnswer {
  id               Int       @id @default(autoincrement())
  attemptId        Int
  stepId           Int
  answerText       String
  createdAt        DateTime  @default(now())
  stepScore        Float?
  criteriaScoresJson String? // JSON object
  feedback         String?
  betterExample    String?

  attempt Attempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  step    TestStep @relation(fields: [stepId], references: [id])

  @@map("attempt_answers")
}

// Voice call session: one row per call (same phone can have many sessions = history of calls).
model VoiceCallSession {
  id               Int       @id @default(autoincrement())
  callId           String    @unique  // UUID from start-voice-call
  to               String    // normalized phone +7...
  scenario         String?   // "dialog" | "realtime" | "realtime_pure"
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  outcome          String?   // "completed" | "no_answer" | "busy" | "failed" | "disconnected"
  durationSec      Int?      // talk time in seconds (null if no answer)
  transcriptJson   String?   // JSON: [{ role: "manager"|"client", text: string }]
  evaluationJson   String?   // same shape as TrainingSession.evaluationJson (V2)
  totalScore       Float?    // 0-100
  failureReason    String?   // if early fail

  @@map("voice_call_sessions")
}

model CallBatch {
  id              String   @id @default(cuid())
  mode            String   @default("manual") // "manual" | "single_dealership" | "all_dealerships"
  status          String   @default("running") // "running" | "paused" | "cancelled" | "completed"
  title           String?
  maxConcurrency  Int      @default(10)
  startIntervalMs Int      @default(250)
  maxAttempts     Int      @default(3)
  totalJobs       Int      @default(0)
  queuedJobs      Int      @default(0)
  inProgressJobs  Int      @default(0)
  completedJobs   Int      @default(0)
  failedJobs      Int      @default(0)
  cancelledJobs   Int      @default(0)
  retryingJobs    Int      @default(0)
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  jobs CallBatchJob[]

  @@map("call_batches")
}

model CallBatchJob {
  id              String   @id @default(cuid())
  batchId         String
  dealershipId    String?
  dealershipName  String?
  phone           String
  status          String   @default("queued") // "queued" | "dialing" | "in_progress" | "retry_wait" | "completed" | "failed" | "cancelled"
  attempt         Int      @default(0)
  maxAttempts     Int      @default(3)
  queuedAt        DateTime @default(now())
  nextRunAt       DateTime @default(now())
  startedAt       DateTime?
  endedAt         DateTime?
  lastError       String?
  lastOutcome     String?
  lastVoiceCallId String?
  linkedAuditId   String?
  linkReason      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  batch    CallBatch         @relation(fields: [batchId], references: [id], onDelete: Cascade)
  attempts CallBatchAttempt[]

  @@index([batchId, status, nextRunAt])
  @@map("call_batch_jobs")
}

model CallBatchAttempt {
  id          String   @id @default(cuid())
  jobId       String
  attempt     Int
  voiceCallId String   @unique
  status      String   @default("dialing") // "dialing" | "ended"
  outcome     String?
  error       String?
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  job CallBatchJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, attempt])
  @@map("call_batch_attempts")
}
